Tabela Serviços
CREATE TABLE Serviço(
    Id_serviço INT PRIMARY KEY,
    Nome_serviço VARCHAR(100) NOT NULL,
    Descrição VARCHAR(255),
    Preço DECIMAL(10,2) NOT NULL,
    Duração_minutos INT,
    FOREIGN KEY (Id_serviço) REFERENCES Serviço(Id_serviço)
    );
